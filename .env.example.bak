# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
PUBLIC_BASE_URL=https://YOUR-APP.onrender.com

# ── Admin dashboard login ────────────────────────────────────────────────────
# Simple password protect the dashboard (change this!)
ADMIN_PASSWORD=changeme123

# ── Google Calendar (service account) ───────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials → Service Account
# Enable "Google Calendar API" for the project first
GOOGLE_CLIENT_EMAIL=your-service@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ── Twilio (for SMS reminders) ───────────────────────────────────────────────
# Your Twilio Account SID and Auth Token from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The Twilio number to send SMS FROM (must be SMS-capable, e.g. your US number)
TWILIO_SMS_FROM=+14246993691

# ── Vapi ─────────────────────────────────────────────────────────────────────
# Your Vapi API key from dashboard.vapi.ai → API Keys
VAPI_API_KEY=your_vapi_api_key_here
